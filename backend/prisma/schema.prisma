generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 用户 =====
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String?  @unique
  phone        String?
  passwordHash String
  avatar       String?
  status       String   @default("ACTIVE")
  role         String   @default("USER")
  balance      Float    @default(0)
  inviteCode   String?  @unique
  inviteBy     String?
  twoFactor    Boolean  @default(false)
  groupId      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group        Group?       @relation(fields: [groupId], references: [id])
  apiKeys      ApiKey[]
  orders       Order[]
  walletLogs   WalletLog[]
  requestLogs  RequestLog[]
  commissions  Commission[]   @relation("UserCommissions")
  inviteCommissions Commission[] @relation("InviteCommissions")
  teamMembers  TeamMember[]
  teams        Team[]         @relation("TeamOwner")

  @@map("users")
}

// ===== API Key =====
model ApiKey {
  id           String    @id @default(uuid())
  userId       String
  name         String
  secret       String    @unique
  status       String    @default("ACTIVE")
  quota        Float?
  usedAmount   Float     @default(0)
  requestCount Int       @default(0)
  expiresAt    DateTime?
  lastUsed     DateTime?
  createdAt    DateTime  @default(now())

  user       User         @relation(fields: [userId], references: [id])
  requestLogs RequestLog[]

  @@map("api_keys")
}

// ===== 模型 =====
model Model {
  id           String   @id @default(uuid())
  name         String
  modelCode    String   @unique
  providerId   String
  inputPrice   Float    @default(0)
  outputPrice  Float    @default(0)
  multiplier   Float    @default(1.0)
  status       String   @default("ACTIVE")
  sortOrder    Int      @default(0)
  groupId      String?
  createdAt    DateTime @default(now())

  provider     Provider    @relation(fields: [providerId], references: [id])
  group        Group?      @relation(fields: [groupId], references: [id])
  requestLogs  RequestLog[]

  @@map("models")
}

// ===== 供应商 =====
model Provider {
  id        String   @id @default(uuid())
  name      String
  baseUrl   String
  apiKey    String
  priority  Int      @default(10)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  models    Model[]

  @@map("providers")
}

// ===== 充值订单 =====
model Order {
  id        String   @id @default(uuid())
  userId    String
  orderNo   String   @unique
  amount    Float
  payType   String
  payUrl    String?
  status    String   @default("PENDING")
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@map("orders")
}

// ===== 钱包流水 =====
model WalletLog {
  id        String   @id @default(uuid())
  userId    String
  type      String
  amount    Float
  balance   Float
  remark    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("wallet_logs")
}

// ===== 请求日志 =====
model RequestLog {
  id               String   @id @default(uuid())
  userId           String
  apiKeyId         String
  modelId          String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  cost             Float    @default(0)
  status           Int      @default(200)
  latency          Int      @default(0)
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])
  apiKey           ApiKey   @relation(fields: [apiKeyId], references: [id])
  model            Model    @relation(fields: [modelId], references: [id])

  @@map("request_logs")
}

// ===== 返佣 =====
model Commission {
  id           String   @id @default(uuid())
  userId       String
  inviteUserId String
  amount       Float
  rate         Float    @default(0.1)
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  user         User     @relation("UserCommissions", fields: [userId], references: [id])
  inviteUser   User     @relation("InviteCommissions", fields: [inviteUserId], references: [id])

  @@map("commissions")
}

// ===== 团队 =====
model Team {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  balance   Float    @default(0)
  createdAt DateTime @default(now())

  owner     User         @relation("TeamOwner", fields: [ownerId], references: [id])
  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  team      Team     @relation(fields: [teamId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("team_members")
}

// ===== 公告 =====
model Announcement {
  id        String    @id @default(uuid())
  title     String
  content   String
  priority  Int       @default(0)
  published Boolean   @default(false)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime  @default(now())

  @@map("announcements")
}

// ===== 分组 =====
model Group {
  id         String   @id @default(uuid())
  name       String   @unique
  multiplier Float    @default(1.0) // 0.1x, 0.18x, 1x, 2x
  desc       String?
  createdAt  DateTime @default(now())

  users      User[]
  models     Model[]

  @@map("groups")
}

// ===== 动态费率 =====
model DynamicRate {
  id        String   @id @default(uuid())
  rate      Float    @default(1.0)  // current dynamic multiplier
  cap       Float    @default(1.0)  // max cap
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("dynamic_rates")
}
