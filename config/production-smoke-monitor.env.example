# MatrixAPI production smoke monitor environment.
# Copy this file to /root/token_API/config/production-smoke-monitor.env on the server.
# Keep the real file out of git and restrict permissions to root.

# Optional webhook alert endpoint. Leave empty to disable external alert delivery.
SMOKE_ALERT_WEBHOOK_URL=

# Optional alert metadata and timeouts.
SMOKE_ALERT_NAME="MatrixAPI production smoke"
SMOKE_ALERT_TIMEOUT_SECONDS=10
SMOKE_MAX_AGE_MINUTES=390
SMOKE_LOG_RETENTION_DAYS=14
