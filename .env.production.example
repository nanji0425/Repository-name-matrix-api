# MatrixAPI production environment template.
# Copy this file to .env on the production server and fill real secrets there.

# Database and cache
DB_PASSWORD=change-me-postgres-password
REDIS_PASSWORD=change-me-redis-password

# New API security secrets. Use random values of at least 32 characters.
SESSION_SECRET=change-me-random-session-secret-at-least-32-chars
CRYPTO_SECRET=change-me-random-crypto-secret-at-least-32-chars

# Public HTTPS entry points
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_TRUSTED_URL=https://matrixapi.online,https://www.matrixapi.online

# Optional runtime tuning
STREAMING_TIMEOUT=300
STREAM_SCANNER_MAX_BUFFER_MB=64
MAX_REQUEST_BODY_MB=64

# Optional bootstrap script inputs. These are used by scripts/bootstrap-new-api.mjs,
# not by the New API container directly.
MATRIXAPI_URL=http://127.0.0.1
NEW_API_ADMIN_USERNAME=aming
NEW_API_ADMIN_PASSWORD=change-me-at-least-8-chars
UPSTREAM_BASE_URL=https://www.kukuai.fyi/api-proxy/china
UPSTREAM_API_KEY=change-me-upstream-key
ZPAY_GATEWAY=https://zpayz.cn/
ZPAY_PID=change-me
ZPAY_KEY=change-me
NEW_API_GROUP_RATIO={"default":1}
NEW_API_TOPUP_GROUP_RATIO={"default":1}
NEW_API_PRICE=1.0
NEW_API_QUOTA_FOR_NEW_USER=500000
NEW_API_DEFAULT_MODELS=gpt-5.5,gpt-5.4,gpt-5.4-openai-compact,gpt-5.5-openai-compact,gpt-image2
