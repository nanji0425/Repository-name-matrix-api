# MatrixAPI production environment template
# Copy this file to .env on the production server and fill real secrets there.

# Database
DB_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Initial admin user used by prisma/seed.ts
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@matrixapi.local
ADMIN_PASSWORD=change-me-at-least-12-characters

# Demo data should remain disabled in production.
ENABLE_DEMO_DATA=false
# DEMO_PASSWORD=change-me-at-least-12-characters
# DEMO_API_KEY=sk-change-me-only-for-non-production-demo-use

# Upstream provider
OPENAI_API_KEY=sk-change-me
UPSTREAM_BASE_URL=https://api.bblabu.cn/v1
UPSTREAM_API_KEY=sk-change-me
# Keep disabled in production so deploy fails if upstream model sync cannot verify the real key/base URL.
ALLOW_FALLBACK_MODELS=false

# ZPay payment gateway
ZPAY_GATEWAY=https://zpayz.cn/
ZPAY_PID=change-me
ZPAY_KEY=change-me
API_PUBLIC_URL=http://matrixapi.online/api
ZPAY_NOTIFY_URL=http://matrixapi.online/api/wallet/zpay/notify
ZPAY_RETURN_URL=http://matrixapi.online/dashboard/balance

# Public frontend/backend URLs
NEXT_PUBLIC_API_URL=http://matrixapi.online/api
FRONTEND_URL=http://matrixapi.online
FRONTEND_URLS=http://matrixapi.online,http://www.matrixapi.online,http://47.82.105.81
